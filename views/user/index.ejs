<%- include('../layout/user_header') %>
    <link rel="stylesheet" href="/css/design-system.css">
    <link rel="stylesheet" href="/css/popular_books.css">
    <script src="https://kit.fontawesome.com/496b9c5c00.js" crossorigin="anonymous"></script>

    <style>
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            min-height: 100vh;
        }

        .main-content {
            padding: 2rem 0;
        }

        /* Carousel Styling */
        .carousel-container {
            margin-bottom: 3rem;
            border-radius: var(--radius-2xl);
            overflow: hidden;
            box-shadow: var(--shadow-2xl);
        }

        .carousel-item img {
            height: 400px;
            object-fit: cover;
            filter: brightness(0.8);
        }

        .carousel-control-prev-icon,
        .carousel-control-next-icon {
            background-color: rgba(139, 92, 246, 0.8);
            border-radius: 50%;
            padding: 1.5rem;
        }

        /* Section Header */
        .section-header {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .section-header h2 {
            font-family: var(--font-heading);
            font-size: var(--font-size-4xl);
            font-weight: var(--font-weight-bold);
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
        }

        .section-header p {
            color: var(--color-text-secondary);
            font-size: var(--font-size-lg);
        }

        /* Books Grid */
        .books-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2rem;
            padding: 0;
        }

        /* Message Display */
        #message {
            position: fixed;
            top: 100px;
            right: 2rem;
            z-index: 1000;
            max-width: 400px;
        }

        .alert-success {
            background: rgba(34, 197, 94, 0.2);
            border: 1px solid rgba(34, 197, 94, 0.5);
            color: #4ade80;
            padding: 1rem;
            border-radius: var(--radius-lg);
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            gap: 0.75rem;
            animation: slideInRight 0.3s ease-out;
        }

        @keyframes slideInRight {
            from {
                transform: translateX(100%);
                opacity: 0;
            }

            to {
                transform: translateX(0);
                opacity: 1;
            }
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: rgba(30, 41, 59, 0.5);
            border-radius: var(--radius-2xl);
            border: 1px solid var(--color-border);
        }

        .empty-state i {
            font-size: 5rem;
            color: var(--color-text-muted);
            margin-bottom: 1.5rem;
        }

        .empty-state h3 {
            color: var(--color-text-primary);
            font-size: var(--font-size-2xl);
            margin-bottom: 0.5rem;
        }

        .empty-state p {
            color: var(--color-text-secondary);
            font-size: var(--font-size-base);
        }

        @media (max-width: 768px) {
            .carousel-item img {
                height: 250px;
            }

            .books-grid {
                grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
                gap: 1.5rem;
            }

            .section-header h2 {
                font-size: var(--font-size-3xl);
            }
        }
    </style>

    <div id="message"></div>

    <div class="container main-content">
        <!-- Carousel -->
        <div class="carousel-container">
            <div id="carouselExample" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <img src="/img/home1.jpg" class="d-block w-100" alt="Library 1">
                    </div>
                    <div class="carousel-item">
                        <img src="/img/home2.jpg" class="d-block w-100" alt="Library 2">
                    </div>
                    <div class="carousel-item">
                        <img src="/img/home3.jpg" class="d-block w-100" alt="Library 3">
                    </div>
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#carouselExample"
                    data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#carouselExample"
                    data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>

        <!-- Popular Books Section -->
        <div class="section-header">
            <h2><i class="fa-solid fa-fire"></i> Popular Books</h2>
            <p>Discover our most popular titles</p>
        </div>

        <% if (books && books.length> 0) { %>
            <div class="books-grid">
                <% books.forEach(book=> { %>
                    <div class="book-card">
                        <div class="book-image">
                            <img src="/img/<%= book.book_img %>" alt="<%= book.book_name %>">
                            <div class="book-badge">
                                <i class="fa-solid fa-fire"></i>
                                <%= book.book_purchase %> sold
                            </div>
                        </div>
                        <div class="book-content">
                            <h3 class="book-title">
                                <%= book.book_name %>
                            </h3>
                            <p class="book-author">
                                <i class="fa-solid fa-user-pen"></i>
                                <%= book.book_author %>
                            </p>
                            <div class="book-meta">
                                <span class="book-category">
                                    <i class="fa-solid fa-tag"></i>
                                    <%= book.book_category %>
                                </span>
                                <span class="book-stock" id="stock-<%= book.book_id %>">
                                    <i class="fa-solid fa-box"></i>
                                    <%= book.book_quantity %> left
                                </span>
                            </div>
                            <div class="book-footer">
                                <span class="book-price">$<%= book.book_price %></span>
                                <div class="book-actions">
                                    <button class="btn-icon" onclick="viewBook('<%= book.book_id %>')"
                                        title="View Details">
                                        <i class="fa-solid fa-eye"></i>
                                    </button>
                                    <button class="btn-cart"
                                        onclick="addToCart('<%= book.book_id %>', '<%= book.book_name %>')">
                                        <i class="fa-solid fa-cart-plus"></i>
                                        Add to Cart
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <% }); %>
            </div>
            <% } else { %>
                <div class="empty-state">
                    <i class="fa-solid fa-book-open"></i>
                    <h3>No Books Available</h3>
                    <p>Check back later for new additions to our library!</p>
                </div>
                <% } %>
    </div>

    <script src="/js/index.js"></script>
    <%- include('../layout/user_footer') %>