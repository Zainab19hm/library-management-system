<%- include('../layout/user_header') %>
    <link rel="stylesheet" href="/css/design-system.css">
    <link rel="stylesheet" href="/css/popular_books.css">
    <script src="https://kit.fontawesome.com/496b9c5c00.js" crossorigin="anonymous"></script>

    <style>
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            min-height: 100vh;
        }

        .books-page {
            padding: 2rem 0;
        }

        .page-header {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .page-header h1 {
            font-family: var(--font-heading);
            font-size: var(--font-size-4xl);
            font-weight: var(--font-weight-bold);
            background: var(--gradient-primary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
        }

        .page-header p {
            color: var(--color-text-secondary);
            font-size: var(--font-size-lg);
        }

        .books-layout {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 2rem;
            align-items: start;
        }

        /* Filter Sidebar */
        .filter-sidebar {
            position: sticky;
            top: 100px;
            background: rgba(30, 41, 59, 0.8);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(139, 92, 246, 0.3);
            border-radius: var(--radius-2xl);
            padding: 1.5rem;
            box-shadow: var(--shadow-lg);
        }

        .filter-header {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 1.5rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid var(--color-border);
        }

        .filter-header h3 {
            color: var(--color-text-primary);
            font-size: var(--font-size-xl);
            font-weight: var(--font-weight-semibold);
            margin: 0;
        }

        .filter-header i {
            color: var(--color-primary);
        }

        .filter-group {
            margin-bottom: 1.5rem;
        }

        .filter-group label.filter-label {
            display: block;
            color: var(--color-text-secondary);
            font-weight: var(--font-weight-semibold);
            font-size: var(--font-size-sm);
            margin-bottom: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .filter-group input[type="text"] {
            width: 100%;
            background: var(--color-bg-tertiary);
            border: 1px solid var(--color-border);
            color: var(--color-text-primary);
            padding: 0.75rem;
            border-radius: var(--radius-md);
            font-size: var(--font-size-sm);
            transition: all var(--transition-fast);
        }

        .filter-group input[type="text"]:focus {
            outline: none;
            border-color: var(--color-primary);
            box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.2);
        }

        .checkbox-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .checkbox-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            cursor: pointer;
            padding: 0.5rem;
            border-radius: var(--radius-sm);
            transition: background var(--transition-fast);
        }

        .checkbox-item:hover {
            background: rgba(139, 92, 246, 0.1);
        }

        .checkbox-item input[type="checkbox"] {
            width: 16px;
            height: 16px;
            cursor: pointer;
            accent-color: var(--color-primary);
        }

        .checkbox-item label {
            color: var(--color-text-secondary);
            font-size: var(--font-size-sm);
            cursor: pointer;
            margin: 0;
        }

        .apply-filters-btn {
            width: 100%;
            padding: 0.875rem;
            background: var(--gradient-primary);
            color: white;
            border: none;
            border-radius: var(--radius-lg);
            font-weight: var(--font-weight-semibold);
            font-size: var(--font-size-base);
            cursor: pointer;
            transition: all var(--transition-base);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }

        .apply-filters-btn:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg), var(--shadow-glow);
        }

        /* Books Grid */
        .books-content {
            min-height: 400px;
        }

        .books-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2rem;
        }

        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            background: rgba(30, 41, 59, 0.5);
            border-radius: var(--radius-2xl);
            border: 1px solid var(--color-border);
        }

        .empty-state i {
            font-size: 5rem;
            color: var(--color-text-muted);
            margin-bottom: 1.5rem;
        }

        .empty-state h3 {
            color: var(--color-text-primary);
            font-size: var(--font-size-2xl);
            margin-bottom: 0.5rem;
        }

        .empty-state p {
            color: var(--color-text-secondary);
        }

        @media (max-width: 768px) {
            .books-layout {
                grid-template-columns: 1fr;
            }

            .filter-sidebar {
                position: relative;
                top: 0;
            }

            .books-grid {
                grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
                gap: 1.5rem;
            }
        }
    </style>

    <div class="container books-page">
        <div class="page-header">
            <h1><i class="fa-solid fa-books"></i> All Books</h1>
            <p>Browse our complete collection</p>
        </div>

        <div class="books-layout">
            <!-- Filter Sidebar -->
            <aside class="filter-sidebar">
                <div class="filter-header">
                    <i class="fa-solid fa-filter"></i>
                    <h3>Filters</h3>
                </div>
                <form id="filterForm">
                    <div class="filter-group">
                        <label for="priceRange" class="filter-label">
                            <i class="fa-solid fa-dollar-sign"></i> Price Range
                        </label>
                        <input type="text" id="priceRange" name="priceRange" placeholder="0-50000">
                    </div>

                    <div class="filter-group">
                        <label class="filter-label">
                            <i class="fa-solid fa-tag"></i> Category
                        </label>
                        <div class="checkbox-group">
                            <div class="checkbox-item">
                                <input type="checkbox" name="category" value="Action" id="cat-action">
                                <label for="cat-action">Action</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="category" value="Crime" id="cat-crime">
                                <label for="cat-crime">Crime</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="category" value="Mystery" id="cat-mystery">
                                <label for="cat-mystery">Mystery</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="category" value="Thriller" id="cat-thriller">
                                <label for="cat-thriller">Thriller</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="category" value="Fantasy" id="cat-fantasy">
                                <label for="cat-fantasy">Fantasy</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="category" value="Science & Technology" id="cat-scifi">
                                <label for="cat-scifi">Science & Technology</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="category" value="Horror" id="cat-horror">
                                <label for="cat-horror">Horror</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="category" value="Romance" id="cat-romance">
                                <label for="cat-romance">Romance</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="category" value="Fiction" id="cat-fiction">
                                <label for="cat-fiction">Fiction</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="category" value="Young Adult" id="cat-ya">
                                <label for="cat-ya">Young Adult</label>
                            </div>
                            <div class="checkbox-item">
                                <input type="checkbox" name="category" value="Education" id="cat-education">
                                <label for="cat-education">Education</label>
                            </div>
                        </div>
                    </div>

                    <div class="filter-group">
                        <label for="author" class="filter-label">
                            <i class="fa-solid fa-user-pen"></i> Author
                        </label>
                        <input type="text" id="author" name="author" placeholder="Author name">
                    </div>

                    <button type="button" class="apply-filters-btn" onclick="applyFilters()">
                        <i class="fa-solid fa-check"></i>
                        Apply Filters
                    </button>
                </form>
            </aside>

            <!-- Books Display -->
            <main class="books-content">
                <div class="books-grid" id="booksContainer">
                    <% if (books && books.length> 0) { %>
                        <% books.forEach(book=> { %>
                            <div class="book-card">
                                <div class="book-image">
                                    <img src="/img/<%= book.book_img %>" alt="<%= book.book_name %>">
                                </div>
                                <div class="book-content">
                                    <h3 class="book-title">
                                        <%= book.book_name %>
                                    </h3>
                                    <p class="book-author">
                                        <i class="fa-solid fa-user-pen"></i>
                                        <%= book.book_author %>
                                    </p>
                                    <div class="book-meta">
                                        <span class="book-category">
                                            <i class="fa-solid fa-tag"></i>
                                            <%= book.book_category %>
                                        </span>
                                    </div>
                                    <div class="book-footer">
                                        <span class="book-price">$<%= book.book_price %></span>
                                        <div class="book-actions">
                                            <button class="btn-icon" onclick="viewBook('<%= book.book_id %>')"
                                                title="View Details">
                                                <i class="fa-solid fa-eye"></i>
                                            </button>
                                            <button class="btn-cart"
                                                onclick="addToCart('<%= book.book_id %>', '<%= book.book_name %>')">
                                                <i class="fa-solid fa-cart-plus"></i>
                                                Add
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <% }); %>
                                <% } else { %>
                                    <div class="empty-state">
                                        <i class="fa-solid fa-book-open"></i>
                                        <h3>No Books Found</h3>
                                        <p>Try adjusting your filters or check back later!</p>
                                    </div>
                                    <% } %>
                </div>
            </main>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="/js/index.js"></script>
    <script>
        function applyFilters() {
            const form = document.getElementById('filterForm');
            const formData = new FormData(form);
            const params = new URLSearchParams(formData);

            fetch(`/user/filterBooks?${params.toString()}`)
                .then(response => response.json())
                .then(books => {
                    const booksContainer = document.getElementById('booksContainer');
                    booksContainer.innerHTML = '';

                    if (books.length > 0) {
                        books.forEach(book => {
                            const bookElement = `
                            <div class="book-card">
                                <div class="book-image">
                                    <img src="/img/${book.book_img}" alt="${book.book_name}">
                                </div>
                                <div class="book-content">
                                    <h3 class="book-title">${book.book_name}</h3>
                                    <p class="book-author">
                                        <i class="fa-solid fa-user-pen"></i>
                                        ${book.book_author}
                                    </p>
                                    <div class="book-meta">
                                        <span class="book-category">
                                            <i class="fa-solid fa-tag"></i>
                                            ${book.book_category}
                                        </span>
                                    </div>
                                    <div class="book-footer">
                                        <span class="book-price">$${book.book_price}</span>
                                        <div class="book-actions">
                                            <button class="btn-icon" onclick="viewBook('${book.book_id}')" title="View Details">
                                                <i class="fa-solid fa-eye"></i>
                                            </button>
                                            <button class="btn-cart" onclick="addToCart('${book.book_id}', '${book.book_name}')">
                                                <i class="fa-solid fa-cart-plus"></i>
                                                Add
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        `;
                            booksContainer.insertAdjacentHTML('beforeend', bookElement);
                        });
                    } else {
                        booksContainer.innerHTML = `
                        <div class="empty-state" style="grid-column: 1 / -1;">
                            <i class="fa-solid fa-book-open"></i>
                            <h3>No Books Found</h3>
                            <p>Try adjusting your filters!</p>
                        </div>
                    `;
                    }
                })
                .catch(error => console.error('Error:', error));
        }
    </script>
    <%- include('../layout/user_footer') %>