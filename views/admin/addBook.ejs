<%- include('../layout/header') %>
  <link rel="stylesheet" href="/css/design-system.css">

  <style>
    body {
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      min-height: 100vh;
      color: var(--color-text-primary);
      padding-bottom: 2rem;
    }

    .books-management {
      padding: 2rem 0;
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 2rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .page-header h1 {
      font-family: var(--font-heading);
      font-size: var(--font-size-3xl);
      font-weight: var(--font-weight-bold);
      background: var(--gradient-secondary);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin: 0;
    }

    /* Books Grid */
    .books-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .admin-book-card {
      background: rgba(30, 41, 59, 0.6);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(20, 184, 166, 0.2);
      border-radius: var(--radius-xl);
      overflow: hidden;
      transition: all var(--transition-base);
      display: flex;
      flex-direction: column;
    }

    .admin-book-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--shadow-xl);
      border-color: rgba(20, 184, 166, 0.4);
    }

    .book-image-container {
      position: relative;
      height: 200px;
      overflow: hidden;
    }

    .book-image-container img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--transition-slow);
    }

    .admin-book-card:hover .book-image-container img {
      transform: scale(1.05);
    }

    .book-status {
      position: absolute;
      top: 10px;
      right: 10px;
      background: rgba(15, 23, 42, 0.8);
      backdrop-filter: blur(4px);
      color: white;
      padding: 0.25rem 0.75rem;
      border-radius: var(--radius-full);
      font-size: 0.75rem;
      font-weight: 600;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .book-content {
      padding: 1.25rem;
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .book-title {
      font-size: var(--font-size-lg);
      font-weight: var(--font-weight-semibold);
      color: var(--color-text-primary);
      margin-bottom: 0.5rem;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .book-author {
      color: var(--color-text-secondary);
      font-size: var(--font-size-sm);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .book-stats {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-bottom: 1.25rem;
      padding-top: 1rem;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
    }

    .stat-item {
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .stat-label {
      font-size: 0.7rem;
      text-transform: uppercase;
      color: var(--color-text-secondary);
      letter-spacing: 0.05em;
    }

    .stat-value {
      font-size: var(--font-size-base);
      font-weight: var(--font-weight-semibold);
      color: var(--color-text-primary);
    }

    .book-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem;
      margin-top: auto;
    }

    .btn-action {
      padding: 0.5rem;
      border-radius: var(--radius-md);
      font-size: var(--font-size-sm);
      font-weight: var(--font-weight-medium);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      transition: all var(--transition-fast);
      border: none;
      cursor: pointer;
    }

    .btn-edit {
      background: rgba(20, 184, 166, 0.1);
      color: var(--color-secondary);
      border: 1px solid rgba(20, 184, 166, 0.2);
    }

    .btn-edit:hover {
      background: var(--gradient-secondary);
      color: white;
    }

    .btn-delete {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
      border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .btn-delete:hover {
      background: #ef4444;
      color: white;
    }

    /* Modal Styling */
    .modal-content {
      background: #1e293b;
      border: 1px solid rgba(20, 184, 166, 0.3);
      border-radius: var(--radius-xl);
    }

    .modal-header {
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(15, 23, 42, 0.5);
      padding: 1.5rem;
    }

    .modal-title {
      color: var(--color-text-primary);
      font-family: var(--font-heading);
    }

    .close {
      color: var(--color-text-secondary);
      text-shadow: none;
      opacity: 1;
    }

    .modal-body {
      padding: 2rem;
    }

    .form-group label {
      color: var(--color-text-secondary);
      font-size: var(--font-size-sm);
      font-weight: var(--font-weight-medium);
      margin-bottom: 0.5rem;
    }

    .form-control {
      background: rgba(15, 23, 42, 0.5);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: white;
      border-radius: var(--radius-md);
      padding: 0.75rem;
    }

    .form-control:focus {
      background: rgba(15, 23, 42, 0.8);
      border-color: var(--color-secondary);
      box-shadow: 0 0 0 3px rgba(20, 184, 166, 0.2);
      color: white;
    }
  </style>

  <div class="container books-management">
    <div class="page-header">
      <h1>Book Management</h1>
      <button id="addBookBtn" class="btn-primary"
        style="width: auto; padding: 0.75rem 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
        <i class="fa-solid fa-plus"></i> Add New Book
      </button>
    </div>

    <!-- Add Book Modal (using same modal structure for add/edit to keep it clean) -->
    <div class="modal fade" id="bookModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="modalTitle">Add New Book</h5>
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
          </div>
          <div class="modal-body">
            <form id="bookForm" action="/admin/addBook" method="POST" enctype="multipart/form-data">
              <div class="row">
                <div class="col-md-6 form-group">
                  <label>Book Title</label>
                  <input type="text" class="form-control" name="title" id="bookTitle" required>
                </div>
                <div class="col-md-6 form-group">
                  <label>Author</label>
                  <input type="text" class="form-control" name="author" id="bookAuthor" required>
                </div>
              </div>

              <div class="row">
                <div class="col-md-6 form-group">
                  <label>Category</label>
                  <select class="form-control" name="category" id="bookCategory" required>
                    <option value="Action">Action</option>
                    <option value="Crime">Crime</option>
                    <option value="Mystery">Mystery</option>
                    <option value="Fantasy">Fantasy</option>
                    <option value="Science & Technology">Science & Technology</option>
                    <option value="Horror">Horror</option>
                    <option value="Thriller">Thriller</option>
                    <option value="Romance">Romance</option>
                    <option value="Fiction">Fiction</option>
                    <option value="Young Adult">Young Adult</option>
                    <option value="Education">Education</option>
                  </select>
                </div>
                <div class="col-md-3 form-group">
                  <label>Price</label>
                  <input type="number" class="form-control" name="price" id="bookPrice" required>
                </div>
                <div class="col-md-3 form-group">
                  <label>Quantity</label>
                  <input type="number" class="form-control" name="quantity" id="bookQuantity" required>
                </div>
              </div>

              <div class="form-group">
                <label>Description</label>
                <textarea class="form-control" name="description" id="bookDescription" rows="3" required></textarea>
              </div>

              <div class="form-group">
                <label>Book Cover Image</label>
                <input type="file" class="form-control-file" name="image" id="bookImage" accept="image/*">
                <small class="text-muted d-block mt-1">Leave empty to keep existing image when editing</small>
              </div>

              <button type="submit" class="btn btn-primary mt-3">
                <i class="fa-solid fa-save"></i> Save Book
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Books Grid -->
    <div class="books-grid">
      <% books.forEach(book=> { %>
        <div class="admin-book-card">
          <div class="book-image-container">
            <img src="/img/<%= book.book_img %>" alt="<%= book.book_name %>">
            <div class="book-status">
              <%= book.book_quantity> 0 ? 'In Stock' : 'Out of Stock' %>
            </div>
          </div>
          <div class="book-content">
            <h3 class="book-title" title="<%= book.book_name %>">
              <%= book.book_name %>
            </h3>
            <div class="book-author">
              <i class="fa-solid fa-user-pen"></i>
              <%= book.book_author %>
            </div>

            <div class="book-stats">
              <div class="stat-item">
                <span class="stat-label">Category</span>
                <span class="stat-value">
                  <%= book.book_category %>
                </span>
              </div>
              <div class="stat-item">
                <span class="stat-label">Price</span>
                <span class="stat-value">$<%= book.book_price %></span>
              </div>
              <div class="stat-item">
                <span class="stat-label">Quantity</span>
                <span class="stat-value">
                  <%= book.book_quantity %>
                </span>
              </div>
              <div class="stat-item">
                <span class="stat-label">Available</span>
                <span class="stat-value" style="color: <%= book.book_quantity > 10 ? '#4ade80' : '#f87171' %>">
                  <%= book.book_quantity> 0 ? 'Yes' : 'No' %>
                </span>
              </div>
            </div>

            <div class="book-actions">
              <button class="btn-action btn-edit" onclick="editBook('<%= book.book_id %>')">
                <i class="fa-solid fa-pen-to-square"></i> Edit
              </button>
              <button class="btn-action btn-delete" onclick="deleteBook('<%= book.book_id %>')">
                <i class="fa-solid fa-trash-can"></i> Delete
              </button>
            </div>
          </div>
        </div>
        <% }); %>
    </div>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.3/dist/js/bootstrap.bundle.min.js"></script>

  <script>
    // Add Book Button
    document.getElementById('addBookBtn').addEventListener('click', function () {
      document.getElementById('modalTitle').textContent = 'Add New Book';
      document.getElementById('bookForm').action = '/admin/addBook';
      document.getElementById('bookForm').reset();
      document.getElementById('bookImage').required = true;
      $('#bookModal').modal('show');
    });

    function editBook(bookId) {
      fetch(`/admin/getBookDetails/${bookId}`)
        .then(response => response.json())
        .then(book => {
          document.getElementById('modalTitle').textContent = 'Edit Book';
          document.getElementById('bookForm').action = `/admin/updateBook/${bookId}`;

          document.getElementById('bookTitle').value = book.book_name;
          document.getElementById('bookAuthor').value = book.book_author;
          document.getElementById('bookCategory').value = book.book_category;
          document.getElementById('bookPrice').value = book.book_price;
          document.getElementById('bookQuantity').value = book.book_quantity;
          document.getElementById('bookDescription').value = book.book_desc;

          // Image is optional for update
          document.getElementById('bookImage').required = false;

          $('#bookModal').modal('show');
        })
        .catch(error => console.error('Error fetching book details:', error));
    }

    function deleteBook(bookId) {
      if (confirm('Are you sure you want to delete this book?')) {
        fetch(`/admin/deleteBook/${bookId}`, { method: 'DELETE' })
          .then(response => {
            if (response.ok) location.reload();
            else alert('Failed to delete book');
          })
          .catch(error => console.error('Error:', error));
      }
    }
  </script>

  <%- include('../layout/footer') %>