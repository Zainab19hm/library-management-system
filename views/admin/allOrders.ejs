<%- include('../layout/header') %>
    <link rel="stylesheet" href="/css/design-system.css">

    <style>
        body {
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
            min-height: 100vh;
            color: var(--color-text-primary);
        }

        .orders-container {
            padding: 2rem 0;
        }

        .page-header {
            text-align: center;
            margin-bottom: 2.5rem;
        }

        .page-header h1 {
            font-family: var(--font-heading);
            font-size: var(--font-size-3xl);
            font-weight: var(--font-weight-bold);
            background: var(--gradient-secondary);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 0.5rem;
        }

        .page-header p {
            color: var(--color-text-secondary);
            font-size: var(--font-size-lg);
        }

        /* Orders Card Grid */
        .orders-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 1.5rem;
        }

        .order-card {
            background: rgba(30, 41, 59, 0.6);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(20, 184, 166, 0.2);
            border-radius: var(--radius-xl);
            padding: 1.5rem;
            transition: all var(--transition-base);
            position: relative;
            overflow: hidden;
        }

        .order-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-xl);
            border-color: rgba(20, 184, 166, 0.4);
        }

        .order-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }

        .order-id {
            font-family: var(--font-mono);
            color: var(--color-secondary);
            font-weight: var(--font-weight-semibold);
            font-size: var(--font-size-sm);
            letter-spacing: 0.05em;
        }

        .order-date {
            color: var(--color-text-secondary);
            font-size: var(--font-size-xs);
            display: flex;
            align-items: center;
            gap: 0.35rem;
        }

        .order-details {
            margin-bottom: 1.5rem;
        }

        .order-item {
            display: flex;
            gap: 1rem;
            margin-bottom: 1rem;
        }

        .item-icon {
            width: 40px;
            height: 40px;
            background: rgba(20, 184, 166, 0.1);
            border-radius: var(--radius-lg);
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--color-secondary);
            flex-shrink: 0;
        }

        .item-info h4 {
            margin: 0;
            font-size: var(--font-size-base);
            font-weight: var(--font-weight-medium);
            color: var(--color-text-primary);
            line-height: 1.4;
        }

        .item-meta {
            font-size: var(--font-size-sm);
            color: var(--color-text-secondary);
            margin-top: 0.25rem;
        }

        .order-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding-top: 1rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        .order-total-label {
            font-size: var(--font-size-xs);
            color: var(--color-text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .order-total-amount {
            font-size: var(--font-size-xl);
            font-weight: var(--font-weight-bold);
            color: white;
        }

        .customer-info {
            background: rgba(15, 23, 42, 0.4);
            border-radius: var(--radius-lg);
            padding: 1rem;
            margin-bottom: 1rem;
            font-size: var(--font-size-sm);
        }

        .customer-row {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            margin-bottom: 0.5rem;
            color: var(--color-text-secondary);
        }

        .customer-row:last-child {
            margin-bottom: 0;
        }

        .customer-row i {
            color: var(--color-secondary);
            width: 16px;
            text-align: center;
        }

        /* Update Status Form */
        .status-form {
            margin-top: 1rem;
            display: flex;
            gap: 0.5rem;
        }

        .status-select {
            flex: 1;
            background: rgba(15, 23, 42, 0.6);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: var(--color-text-primary);
            padding: 0.5rem;
            border-radius: var(--radius-md);
            font-size: var(--font-size-sm);
        }

        .btn-update {
            background: var(--color-secondary);
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: var(--radius-md);
            font-size: var(--font-size-sm);
            cursor: pointer;
            transition: background var(--transition-fast);
        }

        .btn-update:hover {
            background: var(--color-secondary-dark);
        }

        .empty-state {
            grid-column: 1 / -1;
            text-align: center;
            padding: 4rem;
            background: rgba(30, 41, 59, 0.3);
            border-radius: var(--radius-2xl);
            border: 1px dashed rgba(20, 184, 166, 0.3);
        }

        .empty-state i {
            font-size: 4rem;
            color: rgba(255, 255, 255, 0.2);
            margin-bottom: 1.5rem;
        }

        .empty-state h3 {
            color: var(--color-text-secondary);
            margin: 0;
        }

        .btn-back {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--color-text-secondary);
            text-decoration: none;
            margin-bottom: 2rem;
            transition: color var(--transition-fast);
            font-weight: 500;
        }

        .btn-back:hover {
            color: white;
        }
    </style>

    <div class="container orders-container">
        <a href="/admin/dashboard" class="btn-back">
            <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
        </a>

        <div class="page-header">
            <h1>All System Orders</h1>
            <p>Manage and track all customer orders</p>
        </div>

        <% if (orders && orders.length> 0) { %>
            <div class="orders-grid">
                <% orders.forEach(order=> { %>
                    <div class="order-card">
                        <div class="order-header">
                            <span class="order-id">#<%= order.id %></span>
                            <span class="order-date">
                                <i class="fa-regular fa-calendar"></i>
                                Created: <%= order.id %> <!-- Using ID as proxy for date if date missing -->
                            </span>
                            <span
                                class="order-status badge badge-<%= order.status === 'pending' ? 'warning' : 'success' %>">
                                <%= order.status %>
                            </span>
                        </div>

                        <div class="customer-info">
                            <div class="customer-row">
                                <i class="fa-solid fa-user"></i>
                                User ID: <%= order.user_id %>
                            </div>
                        </div>

                        <div class="order-footer">
                            <span class="order-total-label">Total Amount</span>
                            <span class="order-total-amount">₹<%= order.total_price %></span>
                        </div>

                        <form action="/admin/updateOrder/<%= order.id %>" method="POST" class="status-form">
                            <select name="status" class="status-select">
                                <option value="pending" <%=order.status==='pending' ? 'selected' : '' %>>Pending
                                </option>
                                <option value="completed" <%=order.status==='completed' ? 'selected' : '' %>>Completed
                                </option>
                                <option value="cancelled" <%=order.status==='cancelled' ? 'selected' : '' %>>Cancelled
                                </option>
                            </select>
                            <button type="submit" class="btn-update">Update</button>
                        </form>
                    </div>
                    <% }); %>
            </div>
            <% } else { %>
                <div class="empty-state">
                    <i class="fa-solid fa-box-open"></i>
                    <h3>No orders found in the system</h3>
                </div>
                <% } %>
    </div>

    <%- include('../layout/footer') %>